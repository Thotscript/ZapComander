OPENAI_API_KEY=
SECRET_TOKEN=12345
PORT=8443
# --- Ambiente ---
# development | production
NODE_ENV=production
USE_HTTPS=false
# URL base para QR code (sem barra final)
BASE_URL=https://zapbot.botcomander.com.br
# Origem permitida no CORS (* para dev, https://thebroker.vip para prod)
CORS_ORIGIN=*

# --- LM Studio (debug local) ---
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=qwen3.5-4b

# --- Ollama (agentes) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b

# --- Whisper local ---
# Modelos: tiny, base, small, medium, large (quanto menor, mais rápido no CPU)
WHISPER_MODEL=medium