OPENAI_API_KEY=
SECRET_TOKEN=12345
PORT=8443
# --- Ambiente ---
# development | production
NODE_ENV=development
# URL base para QR code (sem barra final)
BASE_URL=http://localhost:8443
# Origem permitida no CORS (* para dev, https://thebroker.vip para prod)
CORS_ORIGIN=*

# --- LM Studio (debug local) ---
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=qwen3.5-4b

# --- Whisper local ---
# Modelos: tiny, base, small, medium, large (quanto menor, mais rápido no CPU)
WHISPER_MODEL=medium